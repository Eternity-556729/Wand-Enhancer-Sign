    <Brush x:Key="Background">#0D1117</Brush>
    <Brush x:Key="Foreground">#E6EDF3</Brush>
    <Brush x:Key="Card">#161B22</Brush>
    <Brush x:Key="CardForeground">#E6EDF3</Brush>
    <Brush x:Key="Popover">#161B22</Brush>
    <Brush x:Key="PopoverForeground">#E6EDF3</Brush>
